{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": true,
  "rewrites": [
    { "source": "/", "destination": "/index.html" }
  ],
  "redirects": [
    { "source": "/savings/regulated-states/", "destination": "/electricity/savings/regulated-states/", "permanent": true },
    { "source": "/savings/fixed-vs-variable/", "destination": "/electricity/savings/fixed-vs-variable/", "permanent": true },
    { "source": "/savings/how-to-switch/", "destination": "/electricity/savings/how-to-switch/", "permanent": true },
    { "source": "/savings/best-fixed-rate-plans/", "destination": "/electricity/savings/best-fixed-rate-plans/", "permanent": true },
    { "source": "/savings/electricity-broker-vs-direct/", "destination": "/electricity/savings/electricity-broker-vs-direct/", "permanent": true },
    { "source": "/savings/states/", "destination": "/electricity/savings/states/", "permanent": true },
    { "source": "/savings/states/:slug/", "destination": "/electricity/savings/states/:slug/", "permanent": true },
    { "source": "/savings/heat-pumps-vs-furnaces/", "destination": "/gas/savings/heat-pumps-vs-furnaces/", "permanent": true },
    { "source": "/savings/best-mvnos/", "destination": "/cellphone/savings/best-mvnos/", "permanent": true },
    { "source": "/savings/switch-carrier/", "destination": "/cellphone/savings/switch-carrier/", "permanent": true },
    { "source": "/savings/cord-cutting/", "destination": "/internet/savings/cord-cutting/", "permanent": true },
    { "source": "/savings/negotiate-bill/", "destination": "/internet/savings/negotiate-bill/", "permanent": true },
    { "source": "/savings/electricity/", "destination": "/electricity/savings/", "permanent": true },
    { "source": "/savings/gas/", "destination": "/gas/savings/", "permanent": true },
    { "source": "/savings/internet/", "destination": "/internet/savings/", "permanent": true },
    { "source": "/savings/cellphone/", "destination": "/cellphone/savings/", "permanent": true },
    { "source": "/savings/water/", "destination": "/water/savings/", "permanent": true },
    { "source": "/savings/security/", "destination": "/security/savings/", "permanent": true },
    { "source": "/assistance/liheap/", "destination": "/electricity/assistance/liheap/", "permanent": true },
    { "source": "/assistance/liheap/:state/", "destination": "/electricity/assistance/liheap/:state/", "permanent": true },
    { "source": "/assistance/lifeline/", "destination": "/internet/assistance/lifeline/", "permanent": true },
    { "source": "/assistance/free-government-phone/", "destination": "/cellphone/assistance/free-government-phone/", "permanent": true },
    { "source": "/assistance/what-replaced-acp/", "destination": "/internet/assistance/what-replaced-acp/", "permanent": true },
    { "source": "/assistance/winter-shutoff-moratoriums/", "destination": "/gas/assistance/winter-shutoff-moratoriums/", "permanent": true },
    { "source": "/assistance/medical-alert/", "destination": "/security/medical-alert/", "permanent": true },
    { "source": "/assistance/electricity/", "destination": "/electricity/assistance/", "permanent": true },
    { "source": "/assistance/gas/", "destination": "/gas/assistance/", "permanent": true },
    { "source": "/assistance/internet/", "destination": "/internet/assistance/", "permanent": true },
    { "source": "/assistance/cellphone/", "destination": "/cellphone/assistance/", "permanent": true },
    { "source": "/assistance/water/", "destination": "/water/assistance/", "permanent": true },
    { "source": "/rates/why-gas-bill-high-winter/", "destination": "/gas/rates/why-gas-bill-high-winter/", "permanent": true },
    { "source": "/liheap/", "destination": "/electricity/assistance/liheap/", "permanent": true },
    { "source": "/liheap/:state/", "destination": "/electricity/assistance/liheap/:state/", "permanent": true },
    { "source": "/lifeline/", "destination": "/internet/assistance/lifeline/", "permanent": true },
    { "source": "/free-government-phone/", "destination": "/cellphone/assistance/free-government-phone/", "permanent": true },
    { "source": "/qualify/submit", "destination": "/qualify/thank-you/", "permanent": false },
    { "source": "/qualify/submit/", "destination": "/qualify/thank-you/", "permanent": false }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(.*).(css|js)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400, stale-while-revalidate=604800" }
      ]
    }
  ]
}
